{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/hooks"],
  "entryPointStrategy": "expand",
  "tsconfig": "tsconfig.json",
  "out": "docs/api",
  "readme": "none",
  "exclude": ["**/*.test.*", "**/*.spec.*"],
  "excludePrivate": true,
  "excludeProtected": true,
  "excludeExternals": true,
  "categorizeByGroup": false
}
